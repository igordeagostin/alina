@using System.Globalization
@using Alina.App.Services
@using Alina.Core.Orchestration
@using Alina.Core.Permissoes
@using Alina.Infrastructure.Llm
@using Microsoft.JSInterop
@inject ConfiguracoesLlmService ConfigLlm
@inject ReconfigurableChatClient Reconfig
@inject ShellUiState UiState
@inject IAssistantStatus Status
@inject VoiceController Voz
@inject ConversationUiState Log
@inject UiConfirmationService Confirmacao
@inject UiConfirmacaoPermissao ConfirmacaoPermissao
@inject IPoliticaPermissao Politica
@inject SeletorPasta SeletorPasta
@inject ConfiguracoesService Config
@inject IJSRuntime JS
@implements IDisposable

<div class="shell @(UiState.Compacto ? "shell--compacto" : "shell--detalhado") shell--@Status.Current.ToString().ToLowerInvariant()">
    <div class="shell__header">
        <img class="shell__logo" src="logo.svg" alt="Alina" />
        <div class="shell__title">Alina</div>
        <button class="modo-toggle" @onclick="AlternarModo" title="@(UiState.Compacto ? "Modo detalhado" : "Modo compacto")">
            @(UiState.Compacto ? "Detalhes" : "Compactar")
        </button>
        <button class="config-toggle" @onclick="AbrirConfiguracoes" title="Configurações">⚙</button>
    </div>

    <div class="voz">
        <div class="orb-area">
            <span class="orb__aura"></span>
            <button class="orb orb--principal" @onclick="AlternarEscutaAsync" disabled="@Ocupado" title="@RotuloMicrofone">
                <span class="orb__pulso"></span>
            </button>
        </div>
        <canvas id="waveform" class="waveform"></canvas>
        <div class="voz__estado">@TextoEstado</div>
        <div class="voz__dica">@DicaEstado</div>
    </div>

    <div class="shell__log">
        @foreach (var m in Log.Snapshot())
        {
            <div class="msg msg--@m.Tipo">@m.Texto</div>
        }
        @if (Status.Current == AssistantState.Thinking)
        {
            <div class="msg msg--bot msg--pending">pensando…</div>
        }
    </div>

    <div class="shell__composer">
        <input class="shell__input"
               placeholder="Ou digite aqui…"
               @bind="_input"
               @bind:event="oninput"
               @onkeydown="OnKeyDown"
               disabled="@Ocupado" />
        <button class="shell__send" @onclick="EnviarTextoAsync" disabled="@(Ocupado || string.IsNullOrWhiteSpace(_input))">
            Enviar
        </button>
    </div>

    @if (_configAberta)
    {
        <div class="cfg">
            <div class="cfg__topo">
                <button class="cfg__voltar" @onclick="FecharConfiguracoes" title="Voltar">←</button>
                <div class="cfg__titulo">Configurações</div>
            </div>

            <div class="cfg__abas">
                <button class="cfg__aba @(_aba == AbaConfig.Geral ? "cfg__aba--ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Geral">Geral</button>
                <button class="cfg__aba @(_aba == AbaConfig.IA ? "cfg__aba--ativa" : "")"
                        @onclick="() => _aba = AbaConfig.IA">IA</button>
                <button class="cfg__aba @(_aba == AbaConfig.Voz ? "cfg__aba--ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Voz">Voz</button>
                <button class="cfg__aba @(_aba == AbaConfig.Permissoes ? "cfg__aba--ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Permissoes">Permissões</button>
            </div>

            <div class="cfg__corpo">
                @if (_aba == AbaConfig.Geral)
                {
                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Iniciar com o Windows</span>
                                <span class="cfg-row__sub">Abre a Alina automaticamente ao ligar o computador</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_iniciarComWindows" />
                        </label>
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Abrir em modo compacto</span>
                                <span class="cfg-row__sub">Mostra só o orbe de voz ao iniciar</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.AbrirEmModoCompacto" />
                        </label>
                    </div>
                }

                @if (_aba == AbaConfig.IA)
                {
                    <div class="cfg-card">
                        <div class="cfg-row cfg-row--empilhado">
                            <span class="cfg-row__titulo">Modelo do cérebro</span>
                            <select class="cfg-campo" @bind="_modeloLlm">
                                @foreach (var m in ConfigLlm.ModelosDisponiveis)
                                {
                                    <option value="@m.Id">@m.Rotulo — @m.Custo</option>
                                }
                            </select>
                            <span class="cfg-row__sub">Modelos mais avançados conversam melhor, porém custam mais por uso. O trabalho pesado de código continua indo para o Claude Code (sua assinatura).</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row--empilhado">
                            <span class="cfg-row__titulo">Chave da API OpenAI</span>
                            <input type="password" class="cfg-campo" @bind="_chaveLlm"
                                   placeholder="@(ConfigLlm.ChaveDefinida ? "•••••••• (definida — deixe em branco para manter)" : "sk-…")" />
                            <span class="cfg-row__sub">Guardada só neste computador, criptografada para o seu usuário do Windows — nunca é versionada nem enviada a lugar nenhum. Usada pelo cérebro (OpenAI) e pela voz.</span>
                        </div>
                    </div>
                }

                @if (_aba == AbaConfig.Voz)
                {
                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Falar as respostas</span>
                                <span class="cfg-row__sub">A Alina lê em voz alta o que responde</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.FalarRespostas" />
                        </label>
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Atender quando eu chamar "Alina"</span>
                                <span class="cfg-row__sub">Escuta a palavra de ativação em segundo plano</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.EscutarPalavraAtivacao" disabled="@(!Config.PalavraAtivacaoDisponivel)" />
                        </label>
                        @if (!Config.PalavraAtivacaoDisponivel)
                        {
                            <div class="cfg-ajuda">
                                <div>Para atender pelo nome, baixe o modelo pequeno de português (Vosk) e extraia de modo que os arquivos fiquem em:</div>
                                <code class="config__ajuda-caminho">@Config.CaminhoModeloVosk</code>
                                <div class="config__ajuda-acoes">
                                    <button class="config__link" @onclick="AbrirSiteVosk">Baixar modelo</button>
                                    <button class="config__link" @onclick="AbrirPastaModelo">Abrir pasta</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row--empilhado">
                            <span class="cfg-row__titulo">Voz da Alina</span>
                            <div class="cfg-voz">
                                <select class="cfg-campo" @bind="_edicao.Voz">
                                    @foreach (var v in Config.VozesDisponiveis)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                                <button class="cfg-voz__ouvir" @onclick="OuvirVozAsync" disabled="@Ocupado"
                                        title="Ouvir uma amostra desta voz">
                                    @(Status.Current == AssistantState.Speaking ? "♪ Tocando…" : "▶ Ouvir")
                                </button>
                            </div>
                        </div>
                        <div class="cfg-row cfg-row--empilhado">
                            <div class="cfg-row__cabecalho">
                                <span class="cfg-row__titulo">Velocidade da fala</span>
                                <span class="cfg-row__valor">@_edicao.VelocidadeFala.ToString("0.0")×</span>
                            </div>
                            <input type="range" class="cfg-range" min="0.5" max="2" step="0.1"
                                   @bind="_edicao.VelocidadeFala" @bind:event="oninput" @bind:culture="CultureInfo.InvariantCulture" />
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row--empilhado">
                            <div class="cfg-row__cabecalho">
                                <span class="cfg-row__titulo">Encerrar após silêncio</span>
                                <span class="cfg-row__valor">@_edicao.SegundosSilencioParaEncerrar.ToString("0.0")s</span>
                            </div>
                            <input type="range" class="cfg-range" min="0.8" max="3" step="0.1"
                                   @bind="_edicao.SegundosSilencioParaEncerrar" @bind:event="oninput" @bind:culture="CultureInfo.InvariantCulture" />
                            <span class="cfg-row__sub">Quando você para de falar, a Alina processa sozinha após esse tempo de silêncio</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Conversa contínua</span>
                                <span class="cfg-row__sub">Depois de responder, volta a ouvir sozinha — sem repetir "Alina" a cada frase</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.ConversaContinua" />
                        </label>
                        <div class="cfg-row cfg-row--empilhado">
                            <div class="cfg-row__cabecalho">
                                <span class="cfg-row__titulo">Janela da conversa</span>
                                <span class="cfg-row__valor">@_edicao.SegundosJanelaConversa.ToString("0")s</span>
                            </div>
                            <input type="range" class="cfg-range" min="5" max="30" step="1"
                                   @bind="_edicao.SegundosJanelaConversa" @bind:event="oninput" />
                            <span class="cfg-row__sub">Quanto tempo ela segue ouvindo antes de dormir e voltar a exigir o nome</span>
                        </div>
                    </div>
                }

                @if (_aba == AbaConfig.Permissoes)
                {
                    <div class="cfg-card">
                        <div class="cfg-row cfg-row--empilhado">
                            <span class="cfg-row__titulo">Quando não houver regra</span>
                            <select class="cfg-campo" @bind="_permOpcoes.ModoPadrao">
                                <option value="@ModoPermissao.Perguntar">Perguntar o que não for coberto</option>
                                <option value="@ModoPermissao.AutoLeitura">Auto-permitir leitura</option>
                                <option value="@ModoPermissao.AceitarEdicoes">Aceitar edições</option>
                                <option value="@ModoPermissao.Autonomia">Autonomia total</option>
                            </select>
                        </div>
                        <label class="cfg-row">
                            <div class="cfg-row__texto">
                                <span class="cfg-row__titulo">Confirmar fora dos diretórios confiáveis</span>
                                <span class="cfg-row__sub">Pede confirmação para ações fora do workspace</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_permOpcoes.ConfirmarForaDoWorkspace" />
                        </label>
                    </div>

                    <div class="config__grupo">
                        <span class="config__grupo-titulo">Diretórios confiáveis (permissão total)</span>
                        @foreach (var d in _permOpcoes.DiretoriosConfiaveis.ToList())
                        {
                            <div class="config__item">
                                <code class="config__item-texto">@d</code>
                                <button class="config__link" @onclick="() => RemoverDiretorio(d)">remover</button>
                            </div>
                        }
                        <div class="config__item">
                            <input class="config__campo" @bind="_novoDiretorio" placeholder="D:\meus-projetos\alina" />
                            <button class="config__link" @onclick="AdicionarDiretorio">adicionar</button>
                        </div>
                        <button class="config__confiar" @onclick="ConfiarNesteProjeto">📁 Confiar num projeto…</button>
                    </div>

                    <ListaEditavel Titulo="Comandos liberados (por prefixo)"
                                   Itens="_permOpcoes.ComandosPermitidos"
                                   Placeholder="dotnet run" />

                    <ListaEditavel Titulo="Comandos que sempre confirmam"
                                   Itens="_permOpcoes.ComandosSempreConfirmar"
                                   Placeholder="git push" />

                    <ListaEditavel Titulo="Caminhos protegidos (segredos)"
                                   Itens="_permOpcoes.CaminhosProtegidos"
                                   Placeholder=".env" />

                    @if (Politica.Regras.Count > 0)
                    {
                        <div class="config__grupo">
                            <span class="config__grupo-titulo">Regras aprendidas</span>
                            @foreach (var r in Politica.Regras)
                            {
                                <div class="config__item">
                                    <code class="config__item-texto">@(r.Permitir ? "✓" : "✕") @(r.Rotulo ?? r.Ferramenta)</code>
                                    <button class="config__link" @onclick="() => RemoverRegra(r.Id)">remover</button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <div class="cfg__rodape">
                <button class="cfg__cancelar" @onclick="FecharConfiguracoes">Cancelar</button>
                <button class="cfg__salvar" @onclick="SalvarConfiguracoes">Salvar alterações</button>
            </div>
        </div>
    }

    @if (_confirmacaoPendente is not null)
    {
        <div class="confirm">
            <div class="confirm__caixa">
                <div class="confirm__titulo">Confirmar ação</div>
                <div class="confirm__acao">@_confirmacaoPendente.Action</div>
                @if (!string.IsNullOrWhiteSpace(_confirmacaoPendente.Details))
                {
                    <pre class="confirm__detalhe">@_confirmacaoPendente.Details</pre>
                }
                <div class="confirm__botoes">
                    <button class="confirm__nao" @onclick="() => Responder(false)">Não</button>
                    <button class="confirm__sim" @onclick="() => Responder(true)">Sim</button>
                </div>
            </div>
        </div>
    }

    @if (_permissaoPendente is not null)
    {
        <div class="confirm">
            <div class="confirm__caixa">
                <div class="confirm__titulo">Permissão do Claude Code</div>
                <div class="confirm__acao">@_permissaoPendente.Pedido.Descricao</div>
                <div class="confirm__botoes confirm__botoes--escopo">
                    <button class="confirm__nao" @onclick="() => ResponderPermissao(false, EscopoPermissao.UmaVez)">Não</button>
                    <button class="confirm__sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.UmaVez)">Uma vez</button>
                    <button class="confirm__sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.SempreNesteDiretorio)">Sempre aqui</button>
                    <button class="confirm__sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.Sempre)">Sempre</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _input = string.Empty;
    private ConfirmationRequest? _confirmacaoPendente;
    private PedidoPermissaoUi? _permissaoPendente;
    private bool _jsPronto;

    private enum AbaConfig { Geral, IA, Voz, Permissoes }

    private bool _configAberta;
    private AbaConfig _aba = AbaConfig.Geral;
    private ConfiguracoesApp _edicao = new();
    private bool _iniciarComWindows;
    private string _modeloLlm = string.Empty;
    private string _chaveLlm = string.Empty;
    private PoliticaPermissaoOptions _permOpcoes = new();
    private string _novoDiretorio = string.Empty;

    private bool Ocupado => Status.Current is AssistantState.Thinking or AssistantState.Executing or AssistantState.Speaking;

    private string RotuloMicrofone => Status.Current switch
    {
        AssistantState.Listening => "Parar de gravar",
        AssistantState.Thinking or AssistantState.Executing => "Processando…",
        AssistantState.Speaking => "Falando…",
        _ => "Falar com a Alina (Ctrl+Espaço)",
    };

    private string TextoEstado => Status.Current switch
    {
        AssistantState.Listening => "ouvindo…",
        AssistantState.Thinking => "pensando…",
        AssistantState.Executing => "executando…",
        AssistantState.Speaking => "falando…",
        _ => "toque para falar",
    };

    private string DicaEstado => Status.Current switch
    {
        AssistantState.Listening => "toque de novo para enviar",
        AssistantState.Executing => "rodando uma ferramenta",
        _ => "modo voz — Ctrl+Espaço de qualquer lugar",
    };

    protected override void OnInitialized()
    {
        UiState.ModoAlterado += AoAlterar;
        Status.Changed += AoMudarStatus;
        Log.Alterado += AoAlterar;
        Voz.NivelAudio += AoNivelAudio;
        Confirmacao.Requested += AoSolicitarConfirmacao;
        ConfirmacaoPermissao.Requested += AoSolicitarPermissao;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _jsPronto = true;
        }
    }

    public void Dispose()
    {
        UiState.ModoAlterado -= AoAlterar;
        Status.Changed -= AoMudarStatus;
        Log.Alterado -= AoAlterar;
        Voz.NivelAudio -= AoNivelAudio;
        Confirmacao.Requested -= AoSolicitarConfirmacao;
        ConfirmacaoPermissao.Requested -= AoSolicitarPermissao;
    }

    private void AoAlterar() => InvokeAsync(StateHasChanged);

    private void AoMudarStatus(object? sender, AssistantState state) => InvokeAsync(StateHasChanged);

    private void AoNivelAudio(float nivel)
    {
        if (!_jsPronto)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            try
            {
                await JS.InvokeVoidAsync("alinaWaveform.push", nivel);
            }
            catch
            {
                // interop pode não estar pronta em transições; ignora
            }
        });
    }

    private Task AoSolicitarConfirmacao(ConfirmationRequest request)
    {
        _confirmacaoPendente = request;
        return InvokeAsync(StateHasChanged);
    }

    private void Responder(bool autorizado)
    {
        _confirmacaoPendente?.Responder(autorizado);
        _confirmacaoPendente = null;
    }

    private Task AoSolicitarPermissao(PedidoPermissaoUi pedido)
    {
        _permissaoPendente = pedido;
        return InvokeAsync(StateHasChanged);
    }

    private void ResponderPermissao(bool autorizado, EscopoPermissao escopo)
    {
        _permissaoPendente?.Responder(autorizado
            ? new RespostaConfirmacaoPermissao(true, escopo)
            : RespostaConfirmacaoPermissao.Negada);
        _permissaoPendente = null;
    }

    private void AdicionarDiretorio()
    {
        var dir = _novoDiretorio.Trim();
        if (dir.Length > 0 && !_permOpcoes.DiretoriosConfiaveis.Contains(dir))
        {
            _permOpcoes.DiretoriosConfiaveis.Add(dir);
        }
        _novoDiretorio = string.Empty;
    }

    private void RemoverDiretorio(string dir) => _permOpcoes.DiretoriosConfiaveis.Remove(dir);

    private void ConfiarNesteProjeto()
    {
        var inicial = _permOpcoes.DiretoriosConfiaveis.LastOrDefault();
        var pasta = SeletorPasta.Escolher(inicial);
        if (!string.IsNullOrWhiteSpace(pasta) && !_permOpcoes.DiretoriosConfiaveis.Contains(pasta))
        {
            _permOpcoes.DiretoriosConfiaveis.Add(pasta);
        }
    }

    private void RemoverRegra(string id) => Politica.RemoverRegra(id);

    private static PoliticaPermissaoOptions ClonarOpcoes(PoliticaPermissaoOptions o) => new()
    {
        ModoPadrao = o.ModoPadrao,
        ConfirmarForaDoWorkspace = o.ConfirmarForaDoWorkspace,
        DiretoriosConfiaveis = [.. o.DiretoriosConfiaveis],
        FerramentasSomenteLeitura = [.. o.FerramentasSomenteLeitura],
        ComandosPermitidos = [.. o.ComandosPermitidos],
        ComandosSempreConfirmar = [.. o.ComandosSempreConfirmar],
        CaminhosProtegidos = [.. o.CaminhosProtegidos],
    };

    private void AlternarModo() => UiState.Alternar();

    private void AbrirConfiguracoes()
    {
        _edicao = new ConfiguracoesApp
        {
            AbrirEmModoCompacto = Config.Atual.AbrirEmModoCompacto,
            FalarRespostas = Config.Atual.FalarRespostas,
            EscutarPalavraAtivacao = Config.Atual.EscutarPalavraAtivacao,
            Voz = Config.Atual.Voz,
            VelocidadeFala = Config.Atual.VelocidadeFala,
            SegundosSilencioParaEncerrar = Config.Atual.SegundosSilencioParaEncerrar,
            ConversaContinua = Config.Atual.ConversaContinua,
            SegundosJanelaConversa = Config.Atual.SegundosJanelaConversa,
        };
        _iniciarComWindows = Config.IniciarComWindows;
        _modeloLlm = ConfigLlm.ModeloAtual;
        _chaveLlm = string.Empty;
        _permOpcoes = ClonarOpcoes(Politica.Opcoes);
        _novoDiretorio = string.Empty;
        _aba = AbaConfig.Geral;
        _configAberta = true;
    }

    private void FecharConfiguracoes() => _configAberta = false;

    private void AbrirSiteVosk() => AbrirExterno(Config.UrlModelosVosk);

    private void AbrirPastaModelo()
    {
        var pasta = System.IO.Directory.GetParent(Config.CaminhoModeloVosk)?.FullName ?? Config.CaminhoModeloVosk;
        try
        {
            System.IO.Directory.CreateDirectory(pasta);
        }
        catch
        {
            // segue mesmo se não conseguir criar
        }

        AbrirExterno(pasta);
    }

    private static void AbrirExterno(string alvo)
    {
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(alvo) { UseShellExecute = true });
        }
        catch
        {
            // ignora falha ao abrir recurso externo
        }
    }

    private void SalvarConfiguracoes()
    {
        Config.IniciarComWindows = _iniciarComWindows;
        Config.Salvar(_edicao);
        Politica.AtualizarOpcoes(_permOpcoes);
        SalvarLlm();
        _configAberta = false;
    }

    private void SalvarLlm()
    {
        ConfigLlm.Salvar(_modeloLlm, _chaveLlm);

        // Aplica modelo/chave ao cérebro em runtime. Sem chave não há o que reconfigurar;
        // se a chave for inválida, mantém o cliente anterior (o erro aparece ao conversar).
        if (ConfigLlm.ChaveDefinida)
        {
            try
            {
                Reconfig.Reconfigurar(ConfigLlm.MontarOpcoesEfetivas());
            }
            catch
            {
                // ignora: o cliente anterior segue válido
            }
        }
    }

    private Task AlternarEscutaAsync() => Voz.AlternarEscutaAsync();

    private Task OuvirVozAsync() => Voz.PrevisualizarVozAsync(_edicao.Voz, _edicao.VelocidadeFala);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await EnviarTextoAsync();
        }
    }

    private async Task EnviarTextoAsync()
    {
        var texto = _input;
        _input = string.Empty;
        await Voz.EnviarTextoAsync(texto);
    }
}
