@using System.Globalization
@using Alina.App.Services
@using Alina.Core.Orchestration
@using Alina.Core.Permissoes
@using Alina.Core.Personalidade
@using Alina.Infrastructure.Configuration
@using Alina.Infrastructure.Llm
@using Microsoft.JSInterop
@inject ConfiguracoesLlmService ConfigLlm
@inject ConfiguracoesClaudeCodeService ConfigClaudeCode
@inject RegistroClientesLlm ClientesLlm
@inject ShellUiState UiState
@inject IAssistantStatus Status
@inject VoiceController Voz
@inject ConversationUiState Log
@inject UiConfirmationService Confirmacao
@inject UiConfirmacaoPermissao ConfirmacaoPermissao
@inject IPoliticaPermissao Politica
@inject SeletorPasta SeletorPasta
@inject PastaDadosService PastaDados
@inject ConfiguracoesService Config
@inject IPersonalidadeStore Personalidade
@inject IJSRuntime JS
@implements IDisposable

<div class="shell @(UiState.Compacto ? "shell-compacto" : "shell-detalhado") shell-@Status.Current.ToString().ToLowerInvariant()">
    <div class="shell-header">
        <img class="shell-logo" src="logo.svg" alt="Alina" />
        <div class="shell-title">Alina</div>
        <button class="modo-toggle" @onclick="AlternarModo" title="@(UiState.Compacto ? "Modo detalhado" : "Modo compacto")">
            @(UiState.Compacto ? "Detalhes" : "Compactar")
        </button>
        <button class="config-toggle" @onclick="AbrirConfiguracoes" title="Configurações">⚙</button>
    </div>

    <div class="voz">
        <div class="orb-area">
            <span class="orb-aura"></span>
            <button class="orb orb-principal" @onclick="AlternarEscutaAsync" title="@RotuloMicrofone">
                <span class="orb-pulso"></span>
            </button>
        </div>
        <canvas id="waveform" class="waveform"></canvas>
        <div class="voz-estado">@TextoEstado</div>
        <div class="voz-dica">@DicaEstado</div>
    </div>

    <div class="shell-log">
        @foreach (var m in Log.Snapshot())
        {
            <div class="msg msg-@m.Tipo">@m.Texto</div>
        }
        @if (Status.Current == AssistantState.Thinking)
        {
            <div class="msg msg-bot msg-pending">pensando…</div>
        }
    </div>

    <div class="shell-composer">
        <input class="shell-input"
               placeholder="Ou digite aqui…"
               @bind="_input"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
        <button class="shell-send" @onclick="EnviarTextoAsync" disabled="@string.IsNullOrWhiteSpace(_input)">
            Enviar
        </button>
    </div>

    @if (_configAberta)
    {
        <div class="cfg">
            <div class="cfg-topo">
                <button class="cfg-voltar" @onclick="FecharConfiguracoes" title="Voltar">←</button>
                <div class="cfg-titulo">Configurações</div>
            </div>

            <div class="cfg-abas">
                <button class="cfg-aba @(_aba == AbaConfig.Geral ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Geral">Geral</button>
                <button class="cfg-aba @(_aba == AbaConfig.Aparencia ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Aparencia">Aparência</button>
                <button class="cfg-aba @(_aba == AbaConfig.IA ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.IA">IA</button>
                <button class="cfg-aba @(_aba == AbaConfig.Personalidade ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Personalidade">Personalidade</button>
                <button class="cfg-aba @(_aba == AbaConfig.Voz ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Voz">Voz</button>
                <button class="cfg-aba @(_aba == AbaConfig.Permissoes ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Permissoes">Permissões</button>
                <button class="cfg-aba @(_aba == AbaConfig.Habilidades ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Habilidades">Habilidades</button>
                <button class="cfg-aba @(_aba == AbaConfig.Ferramentas ? "cfg-aba-ativa" : "")"
                        @onclick="() => _aba = AbaConfig.Ferramentas">Ferramentas</button>
            </div>

            <div class="cfg-corpo">
                @if (_aba == AbaConfig.Geral)
                {
                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Iniciar com o Windows</span>
                                <span class="cfg-row-sub">Abre a Alina automaticamente ao ligar o computador</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_iniciarComWindows" />
                        </label>
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Abrir em modo compacto</span>
                                <span class="cfg-row-sub">Mostra só o orbe de voz ao iniciar</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.AbrirEmModoCompacto" />
                        </label>
                    </div>

                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Mini player na bandeja</span>
                                <span class="cfg-row-sub">Com a janela fechada, um cartão flutuante avisa que a Alina ouviu o nome dela e mostra o diálogo em andamento</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.MostrarMiniPlayer" />
                        </label>
                        @if (_edicao.MostrarMiniPlayer)
                        {
                            <div class="cfg-row cfg-row-empilhado">
                                <span class="cfg-row-titulo">Canto da tela</span>
                                <select class="cfg-campo" @bind="_edicao.CantoMiniPlayer">
                                    <option value="@CantoTela.InferiorDireito">Inferior direito (perto do relógio)</option>
                                    <option value="@CantoTela.InferiorEsquerdo">Inferior esquerdo</option>
                                    <option value="@CantoTela.SuperiorDireito">Superior direito</option>
                                    <option value="@CantoTela.SuperiorEsquerdo">Superior esquerdo</option>
                                </select>
                            </div>
                            <label class="cfg-row">
                                <div class="cfg-row-texto">
                                    <span class="cfg-row-titulo">Mostrar o que foi dito</span>
                                    <span class="cfg-row-sub">Exibe a última fala e a resposta no cartão</span>
                                </div>
                                <input type="checkbox" class="cfg-switch" @bind="_edicao.MiniPlayerMostraTexto" />
                            </label>
                            <CampoDeslizante Titulo="Tempo visível ao terminar"
                                             Descricao="Quanto o cartão continua na tela depois que a Alina termina de responder"
                                             Sufixo="s" Minimo="2" Maximo="20" Passo="1" Casas="0"
                                             Valor="_edicao.SegundosMiniPlayerVisivel"
                                             ValorChanged="(double v) => _edicao.SegundosMiniPlayerVisivel = v" />
                        }
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Pasta de dados</span>
                            <div class="cfg-voz">
                                <input class="cfg-campo" @bind="_pastaDados" placeholder="@PastaDados.PastaAtual" />
                                <button class="cfg-voz-ouvir" @onclick="EscolherPastaDados">Escolher…</button>
                            </div>
                            <span class="cfg-row-sub">Onde a Alina guarda memória, conversas, habilidades e preferências. Ao mudar, o conteúdo atual é movido para o novo local e a Alina reinicia para aplicar.</span>
                        </div>
                    </div>
                }

                @if (_aba == AbaConfig.Aparencia)
                {
                    <div class="cfg-card">
                        <CampoDeslizante Titulo="Tamanho do texto"
                                         Descricao="Aumenta ou diminui o texto de toda a interface. Ajuste conforme a sua distância da tela — a mudança aparece na hora."
                                         Sufixo="%" Minimo="80" Maximo="140" Passo="5" Casas="0" Fator="100"
                                         Valor="_edicao.EscalaInterface"
                                         ValorChanged="AoMudarEscalaAsync" />
                    </div>

                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Lembrar tamanho da janela</span>
                                <span class="cfg-row-sub">Reabre a Alina com a largura e a altura que você deixou em cada modo, compacto e detalhado. Desligado, ela sempre volta ao tamanho padrão.</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.LembrarTamanhoJanela" />
                        </label>
                        @if (_edicao.LembrarTamanhoJanela)
                        {
                            <div class="cfg-row">
                                <div class="cfg-row-texto">
                                    <span class="cfg-row-titulo">Tamanho memorizado</span>
                                    <span class="cfg-row-sub">@TamanhoJanelaMemorizado()</span>
                                </div>
                                <button class="cfg-acao" @onclick="RestaurarTamanhoJanela"
                                        disabled="@(!Config.TemTamanhoJanelaMemorizado)">Restaurar padrão</button>
                            </div>
                        }
                    </div>
                }

                @if (_aba == AbaConfig.IA)
                {
                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Modelos por função</span>
                            <span class="cfg-row-sub">Cada função da Alina pode usar um modelo próprio. Conversar é o que mais roda, então costuma valer um modelo econômico da API; criar e treinar habilidades roda pouco e exige raciocínio — e como só troca texto, pode ir pelo Claude Code, na sua assinatura, sem custo por uso. A conversa fica na API porque é ela que precisa das ferramentas da Alina, e o CLI só enxerga as ferramentas dele.</span>
                        </div>
                    </div>

                    @foreach (PapelLlmInfo papel in ConfigLlm.Papeis)
                    {
                        <div class="cfg-card">
                            <div class="cfg-row cfg-row-empilhado">
                                <span class="cfg-row-titulo">@papel.Titulo</span>
                                <select class="cfg-campo" value="@_selecaoPapel[papel.Papel]"
                                        @onchange="e => _selecaoPapel[papel.Papel] = e.Value?.ToString() ?? string.Empty">
                                    @if (papel.Herdavel)
                                    {
                                        <option value="">Mesmo da conversa — @RotuloDe(_selecaoPapel[PapelLlm.Conversa])</option>
                                    }
                                    <optgroup label="OpenAI (API, cobrada por uso)">
                                        @foreach (ModeloLlm m in ConfigLlm.ModelosDe(papel).Where(m => m.Provedor == LlmProvider.OpenAI))
                                        {
                                            <option value="@m.Selecao">@m.Rotulo — @m.Custo</option>
                                        }
                                    </optgroup>
                                    @if (!papel.ExigeFerramentas)
                                    {
                                        <optgroup label="Claude Code (sua assinatura)">
                                            @foreach (ModeloLlm m in ConfigLlm.ModelosDe(papel).Where(m => m.Provedor == LlmProvider.ClaudeCode))
                                            {
                                                <option value="@m.Selecao">@m.Rotulo — @m.Custo</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                                <span class="cfg-row-sub">@papel.Descricao</span>
                            </div>
                        </div>
                    }

                    <div class="cfg-card">
                        <CampoDeslizante Titulo="Temperatura"
                                         Descricao="Quão previsível a Alina é. Baixa deixa ela mais direta e obediente — entende melhor o pedido e escolhe a ferramenta certa. Alta solta a criatividade e a torna mais errática. Para uma assistente que executa ações, mantenha baixa."
                                         Minimo="ConfiguracoesLlmService.TemperaturaMinima" Maximo="ConfiguracoesLlmService.TemperaturaMaxima"
                                         Passo="0.1" Casas="1"
                                         Valor="_temperatura"
                                         ValorChanged="(double v) => _temperatura = v" />
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Modelo do Claude Code</span>
                            <select class="cfg-campo" @bind="_modeloClaudeCode">
                                @foreach (var m in ConfigClaudeCode.ModelosDisponiveis)
                                {
                                    <option value="@m.Id">@m.Rotulo@(string.IsNullOrEmpty(m.Nota) ? "" : $" — {m.Nota}")</option>
                                }
                            </select>
                            <span class="cfg-row-sub">Modelo que o Claude Code usa nas tarefas de código (via sua assinatura). "Padrão da assinatura" deixa o próprio Claude Code decidir.</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Esforço de raciocínio (texto)</span>
                            <select class="cfg-campo" @bind="_esforcoClaudeCode">
                                @foreach (EsforcoClaudeCode e in ConfigClaudeCode.EsforcosDisponiveis)
                                {
                                    <option value="@e.Id">@e.Rotulo@(string.IsNullOrEmpty(e.Nota) ? "" : $" — {e.Nota}")</option>
                                }
                            </select>
                            <span class="cfg-row-sub">Quanto o Claude Code pensa antes de escrever nos papéis que só redigem texto — criar habilidades e ferramentas. Esforço alto pode gastar dezenas de segundos raciocinando antes da primeira letra sem melhorar o documento; por isso o padrão é baixo.</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Chave da API OpenAI</span>
                            <input type="password" class="cfg-campo" @bind="_chaveOpenAi"
                                   placeholder="@(ConfigLlm.ChaveOpenAiDefinida ? "•••••••• (definida — deixe em branco para manter)" : "sk-…")" />
                            <span class="cfg-row-sub">Única chave de API necessária: vale para os papéis em modelos da OpenAI, para a voz (transcrição e fala) e para a memória semântica. Os modelos Claude acima rodam pela sua assinatura do Claude Code e não pedem chave. Guardada só neste computador, criptografada para o seu usuário do Windows — nunca é versionada nem enviada a lugar nenhum.</span>
                        </div>
                    </div>
                }

                @if (_aba == AbaConfig.Personalidade)
                {
                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Jeito da Alina</span>
                            <span class="cfg-row-sub">Define como ela conversa: quanto fala, quanto se antecipa e o tom. Vale já na próxima mensagem, sem reiniciar.</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <CampoDeslizante Titulo="Extensão das respostas"
                                         Descricao="@($"{TextoPersonalidade.RotuloVerbosidade(_personalidade.Verbosidade)} — quanto texto ela produz por resposta.")"
                                         Minimo="1" Maximo="5" Passo="1" Casas="0"
                                         Valor="_personalidade.Verbosidade"
                                         ValorChanged="(double v) => _personalidade.Verbosidade = (int)v" />
                        <CampoDeslizante Titulo="Iniciativa"
                                         Descricao="@($"{TextoPersonalidade.RotuloProatividade(_personalidade.Proatividade)} — quanto ela sugere próximos passos e oferece ajuda extra depois de concluir.")"
                                         Minimo="1" Maximo="5" Passo="1" Casas="0"
                                         Valor="_personalidade.Proatividade"
                                         ValorChanged="(double v) => _personalidade.Proatividade = (int)v" />
                        <CampoDeslizante Titulo="Humor"
                                         Descricao="@($"{TextoPersonalidade.RotuloHumor(_personalidade.Humor)} — quanta ironia e piada entram no tom.")"
                                         Minimo="1" Maximo="5" Passo="1" Casas="0"
                                         Valor="_personalidade.Humor"
                                         ValorChanged="(double v) => _personalidade.Humor = (int)v" />
                        <CampoDeslizante Titulo="Formalidade"
                                         Descricao="@($"{TextoPersonalidade.RotuloFormalidade(_personalidade.Formalidade)} — o registro da linguagem, do bem solto ao formal.")"
                                         Minimo="1" Maximo="5" Passo="1" Casas="0"
                                         Valor="_personalidade.Formalidade"
                                         ValorChanged="(double v) => _personalidade.Formalidade = (int)v" />
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Orientações para a Alina</span>
                            <textarea class="cfg-textarea" @bind="_personalidade.Instrucoes" rows="8"
                                      placeholder="Ex.: Ao terminar uma tarefa, apenas confirme o que fez. Me chame de Igor. Não repita o comando que executou."></textarea>
                            <span class="cfg-row-sub">Texto livre que entra no início de toda conversa, como um prompt inicial. Tem prioridade sobre os ajustes acima.</span>
                        </div>
                        <div class="config-item config-item-acoes">
                            <button class="config-link" @onclick="RestaurarPersonalidade">restaurar padrão</button>
                        </div>
                    </div>
                }

                @if (_aba == AbaConfig.Voz)
                {
                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Falar as respostas</span>
                                <span class="cfg-row-sub">A Alina lê em voz alta o que responde</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.FalarRespostas" />
                        </label>
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Atender quando eu chamar "Alina"</span>
                                <span class="cfg-row-sub">Escuta a palavra de ativação em segundo plano</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.EscutarPalavraAtivacao" disabled="@(!Config.PalavraAtivacaoDisponivel)" />
                        </label>
                        @if (!Config.PalavraAtivacaoDisponivel)
                        {
                            <div class="cfg-ajuda">
                                <div>Para atender pelo nome, baixe o modelo pequeno de português (Vosk) e extraia de modo que os arquivos fiquem em:</div>
                                <code class="config-ajuda-caminho">@Config.CaminhoModeloVosk</code>
                                <div class="config-ajuda-acoes">
                                    <button class="config-link" @onclick="AbrirSiteVosk">Baixar modelo</button>
                                    <button class="config-link" @onclick="AbrirPastaModelo">Abrir pasta</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Como a Alina entende sua fala</span>
                            <select class="cfg-campo" @bind="_edicao.ModeloTranscricao">
                                @foreach (ModeloTranscricao m in Config.ModelosTranscricaoDisponiveis)
                                {
                                    <option value="@m.Id">@m.Rotulo</option>
                                }
                            </select>
                            <span class="cfg-row-sub">Modelo de transcrição da sua voz. Se a Alina anda "entendendo errado" o que você fala, use um dos modelos GPT-4o — acertam o português muito melhor que o Whisper antigo.</span>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Voz da Alina</span>
                            <div class="cfg-voz">
                                <select class="cfg-campo" @bind="_edicao.Voz">
                                    @foreach (var v in Config.VozesDisponiveis)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                                <button class="cfg-voz-ouvir" @onclick="OuvirVozAsync" disabled="@Ocupado"
                                        title="Ouvir uma amostra desta voz">
                                    @(Status.Current == AssistantState.Speaking ? "♪ Tocando…" : "▶ Ouvir")
                                </button>
                            </div>
                        </div>
                        <CampoDeslizante Titulo="Velocidade da fala"
                                         Sufixo="×" Minimo="0.5" Maximo="2" Passo="0.1" Casas="2"
                                         Valor="_edicao.VelocidadeFala"
                                         ValorChanged="(double v) => _edicao.VelocidadeFala = v" />
                    </div>

                    <div class="cfg-card">
                        <CampoDeslizante Titulo="Encerrar após silêncio"
                                         Descricao="Quando você para de falar, a Alina processa sozinha após esse tempo de silêncio"
                                         Sufixo="s" Minimo="0.8" Maximo="3" Passo="0.1" Casas="2"
                                         Valor="_edicao.SegundosSilencioParaEncerrar"
                                         ValorChanged="(double v) => _edicao.SegundosSilencioParaEncerrar = v" />
                    </div>

                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Conversa contínua</span>
                                <span class="cfg-row-sub">Depois de responder, volta a ouvir sozinha — sem repetir "Alina" a cada frase</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.ConversaContinua" />
                        </label>
                        <CampoDeslizante Titulo="Janela da conversa"
                                         Descricao="Quanto tempo ela segue ouvindo antes de dormir e voltar a exigir o nome"
                                         Sufixo="s" Minimo="5" Maximo="30" Passo="1" Casas="0"
                                         Valor="_edicao.SegundosJanelaConversa"
                                         ValorChanged="(double v) => _edicao.SegundosJanelaConversa = v" />
                    </div>

                    <div class="cfg-card">
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Deixar falar por cima</span>
                                <span class="cfg-row-sub">Falar enquanto ela responde cala a voz dela na hora, como numa conversa de verdade — sem cancelar nada do que ela estiver fazendo. Melhor com fones de ouvido</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_edicao.InterromperPorVoz"
                                   disabled="@(!Config.PalavraAtivacaoDisponivel || !_edicao.EscutarPalavraAtivacao)" />
                        </label>
                        <ListaEditavel Titulo="Palavras que mandam parar de verdade"
                                       Itens="_edicao.PalavrasInterrupcao"
                                       Placeholder="espera" />
                    </div>
                }

                @if (_aba == AbaConfig.Permissoes)
                {
                    <div class="cfg-card">
                        <div class="cfg-row cfg-row-empilhado">
                            <span class="cfg-row-titulo">Quando não houver regra</span>
                            <select class="cfg-campo" @bind="_permOpcoes.ModoPadrao">
                                <option value="@ModoPermissao.Perguntar">Perguntar o que não for coberto</option>
                                <option value="@ModoPermissao.AutoLeitura">Auto-permitir leitura</option>
                                <option value="@ModoPermissao.AceitarEdicoes">Aceitar edições</option>
                                <option value="@ModoPermissao.Autonomia">Autonomia total</option>
                            </select>
                        </div>
                        <label class="cfg-row">
                            <div class="cfg-row-texto">
                                <span class="cfg-row-titulo">Confirmar fora dos diretórios confiáveis</span>
                                <span class="cfg-row-sub">Pede confirmação para ações fora do workspace</span>
                            </div>
                            <input type="checkbox" class="cfg-switch" @bind="_permOpcoes.ConfirmarForaDoWorkspace" />
                        </label>
                    </div>

                    <div class="config-grupo">
                        <span class="config-grupo-titulo">Diretórios confiáveis (permissão total)</span>
                        @foreach (var d in _permOpcoes.DiretoriosConfiaveis.ToList())
                        {
                            <div class="config-item">
                                <code class="config-item-texto">@d</code>
                                <button class="config-link" @onclick="() => RemoverDiretorio(d)">remover</button>
                            </div>
                        }
                        <div class="config-item">
                            <input class="config-campo" @bind="_novoDiretorio" placeholder="D:\meus-projetos\alina" />
                            <button class="config-link" @onclick="AdicionarDiretorio">adicionar</button>
                        </div>
                        <button class="config-confiar" @onclick="ConfiarNesteProjeto">📁 Confiar num projeto…</button>
                    </div>

                    <ListaEditavel Titulo="Comandos liberados (por prefixo)"
                                   Itens="_permOpcoes.ComandosPermitidos"
                                   Placeholder="dotnet run" />

                    <ListaEditavel Titulo="Comandos que sempre confirmam"
                                   Itens="_permOpcoes.ComandosSempreConfirmar"
                                   Placeholder="git push" />

                    <ListaEditavel Titulo="Caminhos protegidos (segredos)"
                                   Itens="_permOpcoes.CaminhosProtegidos"
                                   Placeholder=".env" />

                    @if (Politica.Regras.Count > 0)
                    {
                        <div class="config-grupo">
                            <span class="config-grupo-titulo">Regras aprendidas</span>
                            @foreach (var r in Politica.Regras)
                            {
                                <div class="config-item">
                                    <code class="config-item-texto">@(r.Permitir ? "✓" : "✕") @(r.Rotulo ?? r.Ferramenta)</code>
                                    <button class="config-link" @onclick="() => RemoverRegra(r.Id)">remover</button>
                                </div>
                            }
                        </div>
                    }
                }

                @if (_aba == AbaConfig.Habilidades)
                {
                    <PainelHabilidades />
                }

                @if (_aba == AbaConfig.Ferramentas)
                {
                    <PainelFerramentas />
                }
            </div>

            <div class="cfg-rodape">
                <button class="cfg-cancelar" @onclick="FecharConfiguracoes">Cancelar</button>
                <button class="cfg-salvar" @onclick="SalvarConfiguracoes">Salvar alterações</button>
            </div>
        </div>
    }

    @if (_confirmacaoPendente is not null)
    {
        <div class="confirm">
            <div class="confirm-caixa">
                <div class="confirm-titulo">Confirmar ação</div>
                <div class="confirm-acao">@_confirmacaoPendente.Action</div>
                @if (!string.IsNullOrWhiteSpace(_confirmacaoPendente.Details))
                {
                    <pre class="confirm-detalhe">@_confirmacaoPendente.Details</pre>
                }
                <div class="confirm-botoes">
                    <button class="confirm-nao" @onclick="() => Responder(false)">Não</button>
                    <button class="confirm-sim" @onclick="() => Responder(true)">Sim</button>
                </div>
            </div>
        </div>
    }

    @if (_permissaoPendente is not null)
    {
        <div class="confirm">
            <div class="confirm-caixa">
                <div class="confirm-titulo">Permissão do Claude Code</div>
                <div class="confirm-acao">@_permissaoPendente.Pedido.Descricao</div>
                <div class="confirm-botoes confirm-botoes-escopo">
                    <button class="confirm-nao" @onclick="() => ResponderPermissao(false, EscopoPermissao.UmaVez)">Não</button>
                    <button class="confirm-sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.UmaVez)">Uma vez</button>
                    <button class="confirm-sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.SempreNesteDiretorio)">Sempre aqui</button>
                    <button class="confirm-sim" @onclick="() => ResponderPermissao(true, EscopoPermissao.Sempre)">Sempre</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _input = string.Empty;
    private ConfirmationRequest? _confirmacaoPendente;
    private PedidoPermissaoUi? _permissaoPendente;
    private bool _jsPronto;

    private enum AbaConfig { Geral, Aparencia, IA, Personalidade, Voz, Permissoes, Habilidades, Ferramentas }

    private bool _configAberta;
    private AbaConfig _aba = AbaConfig.Geral;
    private ConfiguracoesApp _edicao = new();
    private bool _iniciarComWindows;
    private readonly Dictionary<PapelLlm, string> _selecaoPapel = [];
    private string _modeloClaudeCode = string.Empty;
    private string _esforcoClaudeCode = string.Empty;
    private string _chaveOpenAi = string.Empty;
    private double _temperatura = 0.3;
    private PoliticaPermissaoOptions _permOpcoes = new();
    private string _novoDiretorio = string.Empty;
    private string _pastaDados = string.Empty;
    private PerfilPersonalidade _personalidade = new();

    private bool Ocupado => Status.Current is AssistantState.Thinking or AssistantState.Executing or AssistantState.Speaking;

    private string RotuloMicrofone => Voz.EmConversa
        ? "Encerrar a conversa"
        : "Falar com a Alina (Ctrl+Espaço)";

    private string TextoEstado => Status.Current switch
    {
        AssistantState.Listening => "ouvindo…",
        AssistantState.Thinking => "pensando…",
        AssistantState.Executing => "executando…",
        AssistantState.Speaking => "falando…",
        _ => "toque para falar",
    };

    private string DicaEstado => Status.Current switch
    {
        AssistantState.Listening => "pode falar — o resto continua rodando",
        AssistantState.Executing => "rodando uma ferramenta — fale à vontade",
        AssistantState.Thinking => "pensando, mas ouvindo você",
        AssistantState.Speaking => "fale por cima que ela para",
        _ => "modo voz — Ctrl+Espaço de qualquer lugar",
    };

    protected override void OnInitialized()
    {
        UiState.ModoAlterado += AoAlterar;
        Status.Changed += AoMudarStatus;
        Log.Alterado += AoAlterar;
        Voz.NivelAudio += AoNivelAudio;
        Confirmacao.Requested += AoSolicitarConfirmacao;
        ConfirmacaoPermissao.Requested += AoSolicitarPermissao;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsPronto = true;
            await AplicarEscalaAsync(Config.Atual.EscalaInterface);
        }
    }

    public void Dispose()
    {
        UiState.ModoAlterado -= AoAlterar;
        Status.Changed -= AoMudarStatus;
        Log.Alterado -= AoAlterar;
        Voz.NivelAudio -= AoNivelAudio;
        Confirmacao.Requested -= AoSolicitarConfirmacao;
        ConfirmacaoPermissao.Requested -= AoSolicitarPermissao;
    }

    private void AoAlterar() => InvokeAsync(StateHasChanged);

    private void AoMudarStatus(object? sender, AssistantState state)
    {
        FecharPendenciasJaRespondidas();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Interromper um turno nega automaticamente o que estava aguardando confirmação;
    /// sem isso, o overlay já resolvido continuaria na tela pedindo um clique inútil.
    /// </summary>
    private void FecharPendenciasJaRespondidas()
    {
        if (_confirmacaoPendente?.Resposta.IsCompleted == true)
        {
            _confirmacaoPendente = null;
        }

        if (_permissaoPendente?.Resposta.IsCompleted == true)
        {
            _permissaoPendente = null;
        }
    }

    private void AoNivelAudio(float nivel)
    {
        if (!_jsPronto)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            try
            {
                await JS.InvokeVoidAsync("alinaWaveform.push", nivel);
            }
            catch
            {
                // interop pode não estar pronta em transições; ignora
            }
        });
    }

    private Task AoSolicitarConfirmacao(ConfirmationRequest request)
    {
        _confirmacaoPendente = request;
        return InvokeAsync(StateHasChanged);
    }

    private void Responder(bool autorizado)
    {
        _confirmacaoPendente?.Responder(autorizado);
        _confirmacaoPendente = null;
    }

    private Task AoSolicitarPermissao(PedidoPermissaoUi pedido)
    {
        _permissaoPendente = pedido;
        return InvokeAsync(StateHasChanged);
    }

    private void ResponderPermissao(bool autorizado, EscopoPermissao escopo)
    {
        _permissaoPendente?.Responder(autorizado
            ? new RespostaConfirmacaoPermissao(true, escopo)
            : RespostaConfirmacaoPermissao.Negada);
        _permissaoPendente = null;
    }

    private void AdicionarDiretorio()
    {
        var dir = _novoDiretorio.Trim();
        if (dir.Length > 0 && !_permOpcoes.DiretoriosConfiaveis.Contains(dir))
        {
            _permOpcoes.DiretoriosConfiaveis.Add(dir);
        }
        _novoDiretorio = string.Empty;
    }

    private void RemoverDiretorio(string dir) => _permOpcoes.DiretoriosConfiaveis.Remove(dir);

    private void ConfiarNesteProjeto()
    {
        var inicial = _permOpcoes.DiretoriosConfiaveis.LastOrDefault();
        var pasta = SeletorPasta.Escolher(inicial);
        if (!string.IsNullOrWhiteSpace(pasta) && !_permOpcoes.DiretoriosConfiaveis.Contains(pasta))
        {
            _permOpcoes.DiretoriosConfiaveis.Add(pasta);
        }
    }

    private void EscolherPastaDados()
    {
        string? pasta = SeletorPasta.Escolher(_pastaDados);
        if (!string.IsNullOrWhiteSpace(pasta))
        {
            _pastaDados = pasta;
        }
    }

    private void RemoverRegra(string id) => Politica.RemoverRegra(id);

    private void RestaurarPersonalidade() => _personalidade = new PerfilPersonalidade();

    private static PoliticaPermissaoOptions ClonarOpcoes(PoliticaPermissaoOptions o) => new()
    {
        ModoPadrao = o.ModoPadrao,
        ConfirmarForaDoWorkspace = o.ConfirmarForaDoWorkspace,
        DiretoriosConfiaveis = [.. o.DiretoriosConfiaveis],
        FerramentasSomenteLeitura = [.. o.FerramentasSomenteLeitura],
        ComandosPermitidos = [.. o.ComandosPermitidos],
        ComandosSempreConfirmar = [.. o.ComandosSempreConfirmar],
        CaminhosProtegidos = [.. o.CaminhosProtegidos],
    };

    private void AlternarModo() => UiState.Alternar();

    private async Task AbrirConfiguracoes()
    {
        _edicao = new ConfiguracoesApp
        {
            AbrirEmModoCompacto = Config.Atual.AbrirEmModoCompacto,
            FalarRespostas = Config.Atual.FalarRespostas,
            EscutarPalavraAtivacao = Config.Atual.EscutarPalavraAtivacao,
            Voz = Config.Atual.Voz,
            VelocidadeFala = Config.Atual.VelocidadeFala,
            SegundosSilencioParaEncerrar = Config.Atual.SegundosSilencioParaEncerrar,
            ConversaContinua = Config.Atual.ConversaContinua,
            SegundosJanelaConversa = Config.Atual.SegundosJanelaConversa,
            InterromperPorVoz = Config.Atual.InterromperPorVoz,
            PalavrasInterrupcao = [.. Config.Atual.PalavrasInterrupcao],
            EscalaInterface = Config.Atual.EscalaInterface,
            LembrarTamanhoJanela = Config.Atual.LembrarTamanhoJanela,
            MostrarMiniPlayer = Config.Atual.MostrarMiniPlayer,
            CantoMiniPlayer = Config.Atual.CantoMiniPlayer,
            MiniPlayerMostraTexto = Config.Atual.MiniPlayerMostraTexto,
            SegundosMiniPlayerVisivel = Config.Atual.SegundosMiniPlayerVisivel,
        };
        _iniciarComWindows = Config.IniciarComWindows;
        _selecaoPapel.Clear();
        foreach (PapelLlmInfo papel in ConfigLlm.Papeis)
        {
            _selecaoPapel[papel.Papel] = ConfigLlm.SelecaoDe(papel.Papel);
        }

        _modeloClaudeCode = ConfigClaudeCode.ModeloAtual;
        _esforcoClaudeCode = ConfigClaudeCode.EsforcoTextoAtual;
        _chaveOpenAi = string.Empty;
        _temperatura = ConfigLlm.Temperatura;
        _permOpcoes = ClonarOpcoes(Politica.Opcoes);
        _novoDiretorio = string.Empty;
        _pastaDados = PastaDados.PastaAtual;
        _personalidade = await Personalidade.ObterAsync();
        _aba = AbaConfig.Geral;
        _configAberta = true;
    }

    private async Task FecharConfiguracoes()
    {
        await AplicarEscalaAsync(Config.Atual.EscalaInterface);
        _configAberta = false;
    }

    private async Task AoMudarEscalaAsync(double escala)
    {
        _edicao.EscalaInterface = escala;
        await AplicarEscalaAsync(escala);
    }

    private string TamanhoJanelaMemorizado()
    {
        List<string> partes = [];
        if (Config.Atual.JanelaCompacta is TamanhoJanela compacta)
        {
            partes.Add($"Compacto {compacta.Largura:0} × {compacta.Altura:0}");
        }

        if (Config.Atual.JanelaDetalhada is TamanhoJanela detalhada)
        {
            partes.Add($"Detalhado {detalhada.Largura:0} × {detalhada.Altura:0}");
        }

        return partes.Count == 0
            ? "Nada memorizado ainda — redimensione a janela e ela guarda o tamanho."
            : string.Join(" · ", partes);
    }

    private void RestaurarTamanhoJanela() => Config.EsquecerTamanhoJanela();

    private async Task AplicarEscalaAsync(double escala)
    {
        if (!_jsPronto)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("alinaInterface.definirEscalaFonte", escala);
        }
        catch
        {
            // interop pode não estar pronta em transições; ignora
        }
    }

    private void AbrirSiteVosk() => AbrirExterno(Config.UrlModelosVosk);

    private void AbrirPastaModelo()
    {
        var pasta = System.IO.Directory.GetParent(Config.CaminhoModeloVosk)?.FullName ?? Config.CaminhoModeloVosk;
        try
        {
            System.IO.Directory.CreateDirectory(pasta);
        }
        catch
        {
            // segue mesmo se não conseguir criar
        }

        AbrirExterno(pasta);
    }

    private static void AbrirExterno(string alvo)
    {
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo(alvo) { UseShellExecute = true });
        }
        catch
        {
            // ignora falha ao abrir recurso externo
        }
    }

    private async Task SalvarConfiguracoes()
    {
        Config.IniciarComWindows = _iniciarComWindows;
        Config.Salvar(_edicao);
        Politica.AtualizarOpcoes(_permOpcoes);
        SalvarLlm();
        ConfigClaudeCode.Salvar(_modeloClaudeCode, _esforcoClaudeCode);
        await Personalidade.SalvarAsync(_personalidade);
        _configAberta = false;

        AplicarPastaDados();
    }

    private void AplicarPastaDados()
    {
        string escolhida = _pastaDados.Trim();
        if (escolhida.Length == 0 ||
            string.Equals(System.IO.Path.GetFullPath(escolhida), System.IO.Path.GetFullPath(PastaDados.PastaAtual), StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            PastaDados.Mover(escolhida);
            ReiniciarApp();
        }
        catch (Exception ex) when (ex is System.IO.IOException or UnauthorizedAccessException)
        {
            // Mantém a pasta anterior se a movimentação falhar (arquivo em uso, permissão, etc.).
        }
    }

    private static void ReiniciarApp()
    {
        string? executavel = Environment.ProcessPath;
        if (!string.IsNullOrWhiteSpace(executavel))
        {
            System.Diagnostics.Process.Start(executavel);
        }

        System.Windows.Application.Current?.Shutdown();
    }

    private string RotuloDe(string selecao)
    {
        ModeloLlm? modelo = ConfigLlm.ModelosDisponiveis.FirstOrDefault(m => m.Selecao == selecao);
        return modelo?.Rotulo ?? selecao;
    }

    private void SalvarLlm()
    {
        ConfigLlm.Salvar(_selecaoPapel, _chaveOpenAi, _temperatura);

        // Aplica modelo/chave aos clientes já criados. Um papel que não puder ser recriado
        // mantém o cliente anterior; se a chave for inválida, o erro aparece ao conversar.
        try
        {
            ClientesLlm.Reconfigurar();
        }
        catch
        {
            // ignora: os clientes anteriores seguem válidos
        }
    }

    private Task AlternarEscutaAsync() => Voz.AlternarEscutaAsync();

    private Task OuvirVozAsync() => Voz.PrevisualizarVozAsync(_edicao.Voz, _edicao.VelocidadeFala);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await EnviarTextoAsync();
        }
    }

    private async Task EnviarTextoAsync()
    {
        var texto = _input;
        _input = string.Empty;
        await Voz.EnviarTextoAsync(texto);
    }
}
